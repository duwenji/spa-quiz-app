{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spa-quiz-app.example.com/schemas/quizset-metadata.json",
  "title": "Quiz Set Metadata Schema",
  "description": "クイズセットのメタデータ（quizSets.json 内の各要素）の形式定義",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "クイズセットの一意な識別子（ケバブケース推奨：quiz-set-id）",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "description": "クイズセットの表示名",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "クイズセットの説明（50-200字推奨）",
      "minLength": 1,
      "maxLength": 500
    },
    "category": {
      "type": "string",
      "description": "カテゴリ（GitHub、アーキテクチャ、技術など）"
    },
    "icon": {
      "type": "string",
      "description": "表示用の絵文字またはアイコン"
    },
    "questionCount": {
      "type": "number",
      "description": "問題数",
      "minimum": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "beginner to intermediate", "beginner to advanced"],
      "description": "難易度レベル"
    },
    "dataPath": {
      "type": ["string", "null"],
      "description": "問題データファイルの相対パス（public/data/ からの相対パス）。親セットで複数の子要素を持つ場合は null の場合がある",
      "pattern": "^([a-z0-9-/]+\\.json)?$"
    },
    "parentId": {
      "type": ["string", "null"],
      "description": "親クイズセットID（階層構造の場合）"
    },
    "group": {
      "type": ["string", "null"],
      "description": "グループ名（複数のセットをグループ化する場合）"
    },
    "level": {
      "type": "number",
      "enum": [1, 2],
      "description": "1=トップレベル、2=子セット"
    },
    "order": {
      "type": "number",
      "description": "表示順序（グループ内の順番）",
      "minimum": 1
    },
    "estimatedLearningTime": {
      "type": "string",
      "description": "推定学習時間（例：\"5-8分\"）"
    },
    "topics": {
      "type": "array",
      "description": "学習トピック一覧",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "category",
    "icon",
    "questionCount",
    "difficulty",
    "dataPath",
    "parentId",
    "group",
    "level",
    "order"
  ],
  "additionalProperties": true,
  "examples": [
    {
      "id": "github-copilot-variables",
      "name": "チャット参加者・スラッシュコマンド・チャット変数について",
      "description": "チャット参加者・スラッシュコマンド・チャット変数を学べるクイズです",
      "category": "GitHub",
      "icon": "🤖",
      "questionCount": 30,
      "difficulty": "intermediate",
      "dataPath": "github-copilot/github-copilot-variables.json",
      "parentId": null,
      "group": null,
      "level": 1,
      "order": 1
    }
  ]
}
