{
  "projectName": "spa-quiz-app",
  "sourceRoot": ".",
  "outputDir": "./ebook-output",
  "formats": ["epub", "pdf", "kdp-markdown"],
  "enablePageList": false,
  "chapterDirPattern": "^docs$",
  "chapterFilePattern": "^.*\\.md$",
  "coverFile": "README.md",
  "mermaidMode": "auto",
  "mermaidFormat": "svg",
  "failOnMermaidError": false,
  "metadataFile": "./.github/skills-config/ebook-build/spa-quiz-app.metadata.yaml",
  "kdpMetadataFile": "./.github/skills-config/ebook-build/spa-quiz-app.kdp.yaml",
  "preserveTemp": false
}
